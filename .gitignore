.DS_Store
__pycache__/
*.py[cod]

# Python environments and local dependency installs
.venv/
venv/
env/
examples/reference/pydeps/
src/*.egg-info/
.pytest_cache/

# Matplotlib and local cache folders
.cache/
.mplconfig/
examples/**/.cache/
examples/**/.mplconfig/

# LaTeX build artifacts
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.run.xml
*.synctex.gz
*.toc

# Rerun output folders. Curated tutorial/reference results stay committed;
# local smoke-test reruns should stay out of version control.
simple_outputs/
example_outputs/
examples/foundations/results/rerun_*/
examples/foundations/results/test_*/
examples/reference/results/test_*/
examples/reference/results/reference_repos_rerun/

# Do not commit local full-paper datasets unless their redistribution rights
# are clear. The repository keeps third-party source files and licenses, but
# avoids vendoring large or externally sourced experiment data by default.
examples/reference/reference_repositories/**/data/
examples/reference/reference_repositories_upstream/
